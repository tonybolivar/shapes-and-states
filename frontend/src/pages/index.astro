---
const PUBLIC_API_URL = import.meta.env.PUBLIC_API_URL;
const PUBLIC_WS_URL = import.meta.env.PUBLIC_WS_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SHAPES & STATES</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Barlow+Condensed:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />

  <style>
    /* ── RESET & BASE ──────────────────────────────── */
    *, *::before, *::after { 
      box-sizing: border-box; 
      margin: 0; padding: 0; 
      user-select: none;
      -webkit-user-select: none;
      -webkit-user-drag: none;
    }

    input { 
      user-select: text !important; 
      -webkit-user-select: text !important; 
    }

    :root {
      --red:         #C41E3A;
      --red-dark:    #8B1428;
      --red-dim:     rgba(196,30,58,0.2);
      --gold:        #D4920A;
      --bg:          #0D0D10;
      --surface:     #141418;
      --panel:       #18181D;
      --white:       #EDE8DC;
      --muted:       #7A7670;
      --dim:         #32302C;
      --header-h:    64px;
    }

    html, body {
      height: 100%; overflow: hidden;
      background: #000; color: var(--white);
      font-family: 'Barlow Condensed', sans-serif;
    }

    /* ── HEADER ────────────────────────────────────── */
    .site-header {
      position: fixed; top: 0; left: 0; right: 0; height: var(--header-h);
      z-index: 1000; background: var(--bg); border-bottom: 3px solid var(--red);
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; padding: 0 24px;
    }

    .site-title { font-family: 'Oswald', sans-serif; font-size: 1.25rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }

    .mode-selector {
      display: flex; gap: 0; border: 2px solid var(--dim);
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    }
    .mode-btn {
      padding: 6px 22px; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--muted); font-family: 'Oswald', sans-serif;
      cursor: pointer; border: none; border-right: 1px solid var(--dim);
      background: var(--surface); transition: color 0.2s, background 0.2s;
    }
    .mode-btn:last-child { border-right: none; }
    .mode-btn:hover:not(.active) { color: var(--white); background: var(--panel); }
    .mode-btn.active { background: var(--red); color: var(--white); }

    .auth-button {
      display: inline-flex; align-items: center; padding: 6px 16px;
      border: 2px solid var(--dim); background: var(--surface);
      font-size: 0.62rem; font-weight: 700; text-transform: uppercase;
      color: var(--white); clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
      text-decoration: none; cursor: pointer;
    }

    .header-right {
      display: flex; align-items: center; justify-content: flex-end; gap: 12px;
      font-family: 'Oswald', sans-serif; font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em; color: var(--white);
    }

    /* ── MAP ───────────────────────────────────────── */
    .map-wrapper {
      position: fixed; top: var(--header-h); left: 0; right: 0; bottom: 0;
      overflow: hidden; background: #000;
      z-index: 1;
    }

    .map-container, .map-transform-layer, .map-wrap-layer { 
      width: 100%; height: 100%; 
      position: relative; 
      pointer-events: none;
    }
    
    .map-transform-layer { position: absolute; left: 0; top: 0; will-change: transform; transform-origin: 0 0; }
    .map-wrap-layer { display: flex; flex-direction: row; }
    .map-instance { flex-shrink: 0; position: relative; pointer-events: auto; }

    .base-map-img { display: block; max-width: none; max-height: none; cursor: crosshair; pointer-events: auto; }

    .borders-layer, .cities-layer { 
      position: absolute; inset: 0; 
      width: 100%; height: 100%;
      pointer-events: none;
    }
    .borders-layer { z-index: 10; }
    .cities-layer { z-index: 5; }

    .borders-layer svg { width: 100%; height: 100%; display: block; pointer-events: none; }
    .borders-layer circle.city-dot {
      pointer-events: all; cursor: pointer;
      fill: white; stroke: var(--red); stroke-width: 3;
      transition: fill 0.2s, stroke 0.2s;
    }
    .borders-layer circle.city-dot:hover { fill: var(--gold); stroke: var(--gold); }
    .borders-layer path {
      pointer-events: all;
      cursor: pointer;
      fill: rgba(255, 255, 255, 0);
      stroke: var(--red);
      stroke-width: 1.5;
      opacity: 0.5;
      transition: all 0.2s;
    }
    .borders-layer path:hover {
      opacity: 1;
      fill: rgba(196, 30, 58, 0.2);
      stroke: var(--gold);
      stroke-width: 3;
    }
    .borders-layer path.selected {
      opacity: 1;
      fill: rgba(196, 30, 58, 0.4);
      stroke: #fff;
      stroke-width: 4;
    }

    .city-marker {
      position: absolute; 
      width: 14px; height: 14px; 
      background: white;
      border: 3px solid var(--red); 
      transform: translate(-50%, -50%);
      box-shadow: 0 0 15px rgba(196,30,58,0.8); 
      pointer-events: none;
      z-index: 20;
    }

    /* ── UI PANELS ───────────────────────────────── */
    .zoom-controls {
      position: fixed; bottom: 24px; right: 24px;
      z-index: 1100; display: flex; flex-direction: column; gap: 8px;
    }
    .zoom-btn {
      width: 48px; height: 48px; background: var(--panel);
      border: 2px solid var(--dim); color: var(--white);
      font-family: 'Oswald', sans-serif; font-size: 1.5rem;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
    }

    .interaction-card {
      position: fixed; bottom: 24px; left: 24px; 
      width: 340px;
      z-index: 1050; background: var(--panel); border: 2px solid var(--red);
      opacity: 0; transform: translateY(20px); pointer-events: none;
      transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      padding: 32px 24px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.8);
      text-align: center;
    }
    .interaction-card.visible { opacity: 1; transform: translateY(0); pointer-events: all; }
    
    #city-input {
      width: 70%; 
      margin: 20px auto;
      display: block;
      padding: 14px;
      background: #000;
      color: var(--white);
      border: 2px solid var(--red);
      font-family: 'Oswald', sans-serif;
      text-transform: uppercase;
      letter-spacing: 2px;
      outline: none;
      box-shadow: inset 0 0 10px rgba(196, 30, 58, 0.3);
      transition: border-color 0.2s, box-shadow 0.2s;
      text-align: center;
    }
    #city-input:focus { border-color: var(--gold); box-shadow: 0 0 20px rgba(212, 146, 10, 0.3); }

    .info-panel {
      position: fixed; top: var(--header-h); right: 0; bottom: 0; width: 360px;
      z-index: 1200; background: var(--panel); border-left: 4px solid var(--red);
      transform: translateX(100%); transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: -20px 0 50px rgba(0,0,0,0.7);
    }
    .info-panel.open { transform: translateX(0); }
    .panel-content { padding: 40px; }

    .coord-readout {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); 
      z-index: 100; background: var(--panel); border: 1px solid var(--dim);
      border-bottom: 3px solid var(--red);
      padding: 10px 24px; opacity: 0; transition: opacity 0.3s; pointer-events: none;
      font-family: 'Oswald'; letter-spacing: 0.1em; font-size: 0.9rem;
      display: flex; gap: 16px; align-items: center;
      min-width: 300px; justify-content: center;
    }
    .coord-readout.visible { opacity: 1; }
    .hover-info { color: var(--gold); border-left: 1px solid var(--dim); padding-left: 16px; font-weight: 600; text-transform: uppercase; }
  </style>
</head>
<body>

<header class="site-header">
  <div class="title-block" style="display:flex; align-items:center; gap:12px;">
    <span style="color:var(--red); font-size:1.5rem;">★</span>
    <h1 class="site-title">Shapes & States</h1>
  </div>
  <div class="mode-selector">
    <button class="mode-btn active" data-mode="view">View</button>
    <button class="mode-btn" data-mode="interact">Interact</button>
  </div>
  <div class="header-right" id="auth-section">
    <a href="#" class="auth-button" id="login-link">Sign in</a>
  </div>
</header>

<main class="map-wrapper" id="map-wrapper">
  <div class="map-container" id="map-container">
    <div class="map-transform-layer" id="map-transform">
      <div class="map-wrap-layer" id="map-wrap">
        <div class="map-instance"><img class="base-map-img" /><div class="borders-layer"></div><div class="cities-layer"></div></div>
        <div class="map-instance"><img class="base-map-img" /><div class="borders-layer"></div><div class="cities-layer"></div></div>
        <div class="map-instance"><img class="base-map-img" /><div class="borders-layer"></div><div class="cities-layer"></div></div>
      </div>
    </div>
  </div>
</main>

<aside class="interaction-card" id="ui-card">
  <div id="ui-card-content">Select a location.</div>
</aside>

<div class="coord-readout" id="coord-display">
  <div>GRID: <span id="coord-x">—</span>, <span id="coord-y">—</span></div>
  <div class="hover-info" id="hover-info" style="display:none;">OWNER: <span id="hover-owner">—</span></div>
</div>

<aside class="info-panel" id="info-panel">
  <div class="panel-content">
    <div style="display:flex; justify-content:space-between; margin-bottom:40px; align-items:flex-start;">
      <div>
        <small style="color:var(--muted); text-transform:uppercase; font-weight:700; font-size:0.65rem; letter-spacing:0.15em;">Settlement Report</small>
        <h2 id="info-city-name" style="font-family:'Oswald'; color:var(--red); text-transform:uppercase; letter-spacing:0.05em; font-size:2rem; line-height:1.1;">—</h2>
      </div>
      <button id="info-close" style="background:none; border:none; color:var(--muted); cursor:pointer; font-size:1.5rem; padding:5px;">✕</button>
    </div>
    <div id="info-data">
      <div style="margin-bottom:32px;">
        <small style="color:var(--muted); text-transform:uppercase; font-weight:700; font-size:0.65rem; letter-spacing:0.1em;">Governed By</small>
        <div id="info-owner-name" style="font-size:1.6rem; color:var(--white); font-family:'Oswald'; margin-top:4px;">—</div>
      </div>
      <div>
        <small style="color:var(--muted); text-transform:uppercase; font-weight:700; font-size:0.65rem; letter-spacing:0.1em;">Strategic Coordinates</small>
        <div id="info-coords" style="font-size:1.4rem; color:var(--gold); font-family:'Oswald'; margin-top:4px;">—</div>
      </div>
    </div>
  </div>
</aside>

<div class="zoom-controls">
  <button class="zoom-btn" data-zoom="in">+</button>
  <button class="zoom-btn" data-zoom="out">−</button>
</div>

<script is:inline define:vars={{ PUBLIC_API_URL, PUBLIC_WS_URL }}>
(function() {
  const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
  const API_URL = PUBLIC_API_URL || (isLocal ? 'http://localhost:8000' : 'https://shapes-and-states.up.railway.app');
  const WS_URL = PUBLIC_WS_URL || API_URL.replace('http', 'ws') + '/ws';
  const API = API_URL;

  const state = {
    cities: [], user: null, mode: 'view', bordersSvg: '',
    target: { zoom: 1, panX: 0, panY: 0 },
    current: { zoom: 1, panX: 0, panY: 0 },
    mouse: { x: window.innerWidth/2, y: window.innerHeight/2 },
    isReady: false, mapWidth: 0, mapHeight: 0
  };

  const ui = {
    wrapper: document.getElementById('map-wrapper'),
    container: document.getElementById('map-container'),
    transform: document.getElementById('map-transform'),
    wrap: document.getElementById('map-wrap'),
    auth: document.getElementById('auth-section'),
    card: document.getElementById('ui-card'),
    cardContent: document.getElementById('ui-card-content'),
    info: document.getElementById('info-panel'),
    coords: document.getElementById('coord-display'),
    hoverInfo: document.getElementById('hover-info'),
    hoverOwner: document.getElementById('hover-owner')
  };

  async function init() {
    const firstImg = document.querySelector('.base-map-img');
    firstImg.src = `${API}/static/base_map.png`;
    const loginLink = document.getElementById('login-link');
    if (loginLink) loginLink.href = `${API}/auth/discord`;
    await fetchAuth();
    await Promise.all([fetchCities(), loadBorders()]);
    if (firstImg.complete) onReady(); else firstImg.onload = onReady;
    setupEvents(); connectWS();
    requestAnimationFrame(renderLoop);
  }

  function onReady() {
    if (state.isReady) return;
    const firstImg = document.querySelector('.base-map-img');
    state.mapWidth = firstImg.naturalWidth;
    state.mapHeight = firstImg.naturalHeight;
    document.querySelectorAll('.base-map-img').forEach(img => img.src = `${API}/static/base_map.png`);
    document.querySelectorAll('.map-instance').forEach(el => { 
      el.style.width = state.mapWidth + 'px'; el.style.height = state.mapHeight + 'px'; 
    });
    const vW = window.innerWidth; const vH = ui.wrapper.clientHeight;
    state.target.panX = (vW / 2) - state.mapWidth; 
    state.target.panY = (vH / 2) - (state.mapHeight / 2);
    state.current.panX = state.target.panX; state.current.panY = state.target.panY;
    state.isReady = true; renderBorders(); renderCities();
  }

  async function fetchAuth() {
    try {
      const r = await fetch(`${API}/auth/me`, { credentials: 'include' });
      const d = await r.json();
      if (d.authenticated) {
        state.user = d;
        ui.auth.innerHTML = `<span>${d.username}</span> <a href="${API}/auth/logout" class="auth-button" style="margin-left:15px;">Logout</a>`;
      }
    } catch(e) {}
  }

  async function fetchCities() {
    try {
      const r = await fetch(`${API}/cities`);
      state.cities = await r.json();
      renderCities();
    } catch(e) {}
  }

  async function loadBorders() {
    try {
      const r = await fetch(`${API}/data/borders.svg`);
      if (r.ok) { state.bordersSvg = await r.text(); renderBorders(); }
    } catch(e) {}
  }

  function renderLoop() {
    if (state.mapWidth > 0) {
      const lerp = 0.15; const margin = 100; const speed = 20;
      if (state.mouse.x < margin) state.target.panX += ((margin - state.mouse.x) / margin) * speed;
      else if (state.mouse.x > window.innerWidth - margin) state.target.panX -= ((state.mouse.x - (window.innerWidth - margin)) / margin) * speed;
      if (state.mouse.y < margin + 64) state.target.panY += ((margin + 64 - state.mouse.y) / margin) * speed;
      else if (state.mouse.y > window.innerHeight - margin) state.target.panY -= ((state.mouse.y - (window.innerHeight - margin)) / margin) * speed;

      const wrapW = state.mapWidth * state.target.zoom;
      if (state.target.panX > 0) { state.target.panX -= wrapW; state.current.panX -= wrapW; }
      if (state.target.panX < -wrapW * 2) { state.target.panX += wrapW; state.current.panX += wrapW; }

      const vH = ui.wrapper.clientHeight;
      const scaledH = state.mapHeight * state.target.zoom;
      if (scaledH > vH) state.target.panY = Math.min(Math.max(state.target.panY, vH - scaledH), 0);
      else state.target.panY = (vH - scaledH) / 2;

      state.current.zoom += (state.target.zoom - state.current.zoom) * lerp;
      state.current.panX += (state.target.panX - state.current.panX) * lerp;
      state.current.panY += (state.target.panY - state.current.panY) * lerp;
      ui.transform.style.transform = `translate(${state.current.panX}px, ${state.current.panY}px) scale(${state.current.zoom})`;
    }
    requestAnimationFrame(renderLoop);
  }

  function renderBorders() {
    if (!state.bordersSvg || !state.isReady) return;
    document.querySelectorAll('.borders-layer').forEach(layer => { layer.innerHTML = state.bordersSvg; });
  }

  function renderCities() {
    if (!state.mapWidth || !state.isReady) return;
    const NS = 'http://www.w3.org/2000/svg';
    document.querySelectorAll('.borders-layer').forEach(layer => {
      layer.querySelectorAll('circle.city-dot').forEach(el => el.remove());
      const svg = layer.querySelector('svg');
      if (!svg) return;
      state.cities.forEach(c => {
        const circle = document.createElementNS(NS, 'circle');
        circle.setAttribute('cx', c.x); circle.setAttribute('cy', c.y); circle.setAttribute('r', 6);
        circle.classList.add('city-dot');
        circle.addEventListener('click', (e) => {
          e.stopPropagation();
          document.querySelectorAll('path.selected').forEach(p => p.classList.remove('selected'));
          document.querySelectorAll(`.borders-layer path[id="${c.id}"]`).forEach(p => p.classList.add('selected'));
          document.getElementById('info-city-name').textContent = c.name;
          document.getElementById('info-owner-name').textContent = c.username || 'Citizen';
          document.getElementById('info-coords').textContent = `${c.x}, ${c.y}`;
          ui.info.classList.add('open'); ui.card.classList.remove('visible');
        });
        svg.appendChild(circle);
      });
    });
  }

  function getCoords(e) {
    if (!state.isReady) return null;
    const instance = e.target.closest('.map-instance');
    if (!instance) return null;
    const rect = instance.getBoundingClientRect();
    let x = (e.clientX - rect.left) * (state.mapWidth / rect.width);
    let y = (e.clientY - rect.top) * (state.mapHeight / rect.height);
    x = ((x % state.mapWidth) + state.mapWidth) % state.mapWidth;
    if (y < 0 || y > state.mapHeight) return null;
    return { x: Math.round(x), y: Math.round(y) };
  }

  function setupEvents() {
    window.addEventListener('mousemove', (e) => {
      state.mouse.x = e.clientX; state.mouse.y = e.clientY;
      const c = getCoords(e);
      const path = e.target.closest('path');
      if (path) {
        const city = state.cities.find(city => city.id === path.id);
        ui.hoverOwner.textContent = city ? (city.username || 'Citizen') : 'Neutral';
        ui.hoverInfo.style.display = 'block';
      } else {
        ui.hoverInfo.style.display = 'none';
      }
      if (c) {
        document.getElementById('coord-x').textContent = c.x;
        document.getElementById('coord-y').textContent = c.y;
        ui.coords.classList.add('visible');
      } else ui.coords.classList.remove('visible');
    });

    ui.wrapper.addEventListener('wheel', (e) => {
      e.preventDefault();
      const delta = e.deltaY > 0 ? 0.85 : 1.15;
      const oldZ = state.target.zoom;
      state.target.zoom = Math.min(Math.max(state.target.zoom * delta, 0.4), 10);
      const rect = ui.wrapper.getBoundingClientRect();
      const mx = e.clientX - rect.left; const my = e.clientY - rect.top;
      state.target.panX = mx - (mx - state.target.panX) * (state.target.zoom / oldZ);
      state.target.panY = my - (my - state.target.panY) * (state.target.zoom / oldZ);
    }, { passive: false });

    ui.wrapper.addEventListener('click', (e) => {
      const path = e.target.closest('path');
      if (path) {
        e.stopPropagation();
        const city = state.cities.find(c => c.id === path.id);
        document.querySelectorAll('path.selected').forEach(p => p.classList.remove('selected'));
        document.querySelectorAll(`.borders-layer path[id="${path.id}"]`).forEach(p => p.classList.add('selected'));
        document.getElementById('info-city-name').textContent = city ? city.name : path.id;
        document.getElementById('info-owner-name').textContent = city ? (city.username || 'Citizen') : 'Neutral Territory';
        document.getElementById('info-coords').textContent = city ? `${city.x}, ${city.y}` : 'Unmapped';
        ui.info.classList.add('open'); ui.card.classList.remove('visible');
        return;
      }

      if (e.target.closest('.base-map-img')) {
        ui.info.classList.remove('open');
        document.querySelectorAll('path.selected').forEach(p => p.classList.remove('selected'));
        if (state.mode === 'interact') {
          const c = getCoords(e); if (!c) return;
          ui.card.classList.add('visible');
          if (!state.user) {
            ui.cardContent.innerHTML = `<p style='color:var(--muted);'>LOGIN REQUIRED</p>`;
          } else if (state.user.has_city && !state.user.debug_mode) {
            const mine = state.cities.find(c => c.owner === state.user.discord_id);
            ui.cardContent.innerHTML = `
              <p style='color:var(--red); font-family:Oswald; font-size:1rem; letter-spacing:0.1em;'>CITY ALREADY FOUNDED</p>
              ${mine ? `<p style='color:var(--gold); margin-top:10px; font-family:Oswald;'>${mine.name}</p><p style='color:var(--muted); font-size:0.75rem; margin-top:4px;'>${mine.x}, ${mine.y}</p>` : ''}
            `;
          } else {
            ui.cardContent.innerHTML = `
              <h3 style='font-family:Oswald; color:var(--red); margin-bottom:12px;'>ESTABLISH SETTLEMENT</h3>
              <p style='color:var(--gold); margin-bottom:16px; font-size:0.85rem;'>COORDINATES: ${c.x}, ${c.y}</p>
              <input type="text" id="city-input" placeholder="SETTLEMENT NAME" autocomplete="off"/>
              <button id="city-submit" style="background:var(--red); color:white; border:none; padding:12px; width:100%; cursor:pointer; font-family:Oswald; font-weight:700; width:100%;">CONFIRM FOUNDATION</button>
            `;
            document.getElementById('city-submit').onclick = async () => {
              const name = document.getElementById('city-input').value.trim();
              if (!name) return;
              try {
                const r = await fetch(`${API}/web/city`, {
                  method: 'POST', headers: { 'Content-Type': 'application/json' },
                  body: JSON.stringify({ name, x: c.x, y: c.y }), credentials: 'include'
                });
                if (r.ok) { 
                  ui.cardContent.innerHTML = "<p style='color:var(--gold); font-family:Oswald;'>ESTABLISHED.</p>"; 
                  state.user.has_city = true; setTimeout(() => ui.card.classList.remove('visible'), 2000); 
                } else { const d = await r.json(); alert(d.detail); }
              } catch(e) {}
            };
          }
        }
      }
    });

    document.querySelectorAll('.mode-btn').forEach(btn => {
      btn.onclick = () => {
        state.mode = btn.dataset.mode;
        document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        if (state.mode === 'view') ui.card.classList.remove('visible');
      };
    });

    document.getElementById('info-close').onclick = () => { ui.info.classList.remove('open'); document.querySelectorAll('path.selected').forEach(s => s.classList.remove('selected')); };
    
    document.querySelectorAll('.zoom-btn').forEach(btn => {
      btn.onclick = () => {
        const delta = btn.dataset.zoom === 'in' ? 1.5 : 1/1.5;
        const oldZ = state.target.zoom;
        state.target.zoom = Math.min(Math.max(state.target.zoom * delta, 0.4), 10);
        const mx = window.innerWidth / 2; const my = window.innerHeight / 2;
        state.target.panX = mx - (mx - state.target.panX) * (state.target.zoom / oldZ);
        state.target.panY = my - (my - state.target.panY) * (state.target.zoom / oldZ);
      };
    });
  }

  function connectWS() {
    const ws = new WebSocket(WS_URL);
    ws.onmessage = e => {
      const d = JSON.parse(e.data);
      if (d.type === 'borders_update') { state.bordersSvg = d.svg; renderBorders(); fetchCities(); }
    };
    ws.onclose = () => setTimeout(connectWS, 3000);
  }

  init();
})();
</script>
</body>
</html>
